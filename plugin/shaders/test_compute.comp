#version 440
layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(binding = 0, rgba8) writeonly uniform image2D outImg;

void main() {
    ivec2 pos = ivec2(gl_GlobalInvocationID.xy);
    float r = float(pos.x) / 255.0;
    float g = float(pos.y) / 255.0;
    imageStore(outImg, pos, vec4(r, g, 0.0, 1.0));
}
